VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# VITE_* variables are required at Vercel build time.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Server-only variables are required at Vercel Function runtime.

# In production, use the Supabase transaction pooler URL on port 6543.
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# Optional: required only if the support form should send email.
SUPPORT_EMAIL=support@example.com
SUPPORT_EMAIL_PASSWORD=your-app-password
